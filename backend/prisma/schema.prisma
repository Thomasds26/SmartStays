generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  role            String   // "ADMIN", "VERHUURDER", "SCHOONMAKER"
  password        String?
  isActive        Boolean  @default(false)
  activationToken String?
  personalCode    String?  // 6-cijferige code voor schoonmaker
  createdAt       DateTime @default(now())
  
  properties       Property[]
  personalCodes    PersonalCode[]
  cleaningTasks    CleaningTask[]
  cleaningReserves CleaningReserve[]
}

model Property {
  id               String   @id @default(cuid())
  name             String
  address          String?
  ownerId          String
  cleaningDuration Int      @default(90)
  airbnbIcalUrl    String?  // iCal URL voor Airbnb
  bookingIcalUrl   String?  // iCal URL voor Booking.com
  createdAt        DateTime @default(now())
  
  owner          User            @relation(fields: [ownerId], references: [id])
  bookings       Booking[]
  cleaningTasks  CleaningTask[]
  integrations   Integration[]
  calendarEvents CalendarEvent[]
}

model Booking {
  id         String   @id @default(cuid())
  externalId String   @unique
  source     String
  guestName  String
  guestEmail String
  checkIn    DateTime
  checkOut   DateTime
  propertyId String
  
  property Property @relation(fields: [propertyId], references: [id])
}

model PersonalCode {
  id        String   @id @default(cuid())
  name      String
  code      String
  userId    String
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
}

model CleaningTask {
  id          String   @id @default(cuid())
  propertyId  String
  scheduledAt DateTime
  duration    Int
  status      String   @default("OPEN")
  cleanerId   String?
  notes       String?
  createdAt   DateTime @default(now())
  
  property Property     @relation(fields: [propertyId], references: [id])
  cleaner  User?        @relation(fields: [cleanerId], references: [id])
  reserves CleaningReserve[]
}

model CleaningReserve {
  id        String   @id @default(cuid())
  taskId    String
  cleanerId String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  
  task    CleaningTask @relation(fields: [taskId], references: [id])
  cleaner User         @relation(fields: [cleanerId], references: [id])
  
  @@unique([taskId, cleanerId])
}

model Integration {
  id          String   @id @default(cuid())
  propertyId  String
  platform    String
  apiKey      String?
  webhookUrl  String?
  icalUrl     String?
  lastSync    DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  property Property @relation(fields: [propertyId], references: [id])
  
  @@unique([propertyId, platform])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  externalId  String   @unique
  propertyId  String
  platform    String
  guestName   String?
  guestEmail  String?
  checkIn     DateTime
  checkOut    DateTime
  status      String   @default("ACTIVE")
  rawData     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  property Property @relation(fields: [propertyId], references: [id])
  
  @@unique([propertyId, externalId])
}